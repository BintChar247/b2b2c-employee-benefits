# ============================================================
# B2B2C Employee Benefits Portal — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required for frontend (public-safe Supabase anon key)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Required for tools/setup_supabase.py and tools/seed_offers.py ONLY
# NEVER expose SUPABASE_SERVICE_KEY in frontend code
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
