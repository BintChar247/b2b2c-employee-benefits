# ============================================================
# B2B2C Employee Benefits Portal — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required for frontend (public-safe Supabase anon key)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Required for admin page (/admin.html) — bypasses RLS, allows full CRUD
# WARNING: This key is embedded in the built JS bundle. Restrict /admin.html at the
# hosting/CDN layer (IP allowlist, basic auth, deployment protection) before using this.
VITE_SUPABASE_SERVICE_KEY=your-service-role-key-here

# Required for tools/setup_supabase.py and tools/seed_offers.py ONLY
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
